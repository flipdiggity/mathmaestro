generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(cuid())
  clerkId          String        @unique
  email            String        @unique
  name             String?
  stripeCustomerId String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  children         Child[]
  usageRecords     UsageRecord[]
}

model Child {
  id             String         @id @default(cuid())
  name           String
  grade          Int            // engine grade: which curriculum sequence they work in
  track          String         // e.g. "accelerated", "standard"
  state          String         @default("TX")
  district       String         @default("eanes-isd")
  targetTestDate DateTime?
  // Named course preset (see src/lib/curriculum/courses.ts). When set it defines
  // the topic sequence + start floor, superseding (grade, track) resolution.
  courseId       String?
  // The grade the child is actually IN at school, for display (e.g. Eliana is a
  // 6th grader whose engine grade is 7 because she takes Math 8 Accelerated).
  displayGrade   Int?
  // Finish-by date for the current study plan (e.g. first day of school). Drives
  // required pace: topics remaining / weekdays left.
  planEndDate    DateTime?
  emailEnabled   Boolean        @default(true)
  createdAt      DateTime       @default(now())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  worksheets     Worksheet[]
  topicMastery   TopicMastery[]

  @@index([userId])
}

model Worksheet {
  id            String         @id @default(cuid())
  childId       String
  child         Child          @relation(fields: [childId], references: [id])
  title         String
  weekNumber    Int?
  dayOfWeek     String?        // "Monday", "Tuesday", etc.
  questionsJson String         // JSON array of questions with answers
  topicIdsJson  String         // JSON array of topic IDs covered
  status        String         @default("generated") // generated, printed, graded
  createdAt     DateTime       @default(now())
  gradingResult GradingResult?
}

model GradingResult {
  id             String   @id @default(cuid())
  worksheetId    String   @unique
  worksheet      Worksheet @relation(fields: [worksheetId], references: [id])
  photoUrl       String?
  totalQuestions  Int
  correctCount   Int
  scorePercent   Float
  resultsJson    String   // JSON array of per-question results
  createdAt      DateTime @default(now())
}

model TopicMastery {
  id              String   @id @default(cuid())
  childId         String
  child           Child    @relation(fields: [childId], references: [id])
  topicId         String
  topicName       String
  gradeLevel      Int
  mastery         Float    @default(0) // 0-100 (graded evidence, EMA)
  timesPracticed  Int      @default(0) // GRADED practice events
  lastPracticedAt DateTime?
  lastScore       Float?
  // ── Adaptive-difficulty state (see src/lib/adaptive.ts) ──
  // Graded ladder position 1..4. Serves since the last grade escalate the
  // EFFECTIVE difficulty on top of this without mutating it.
  difficultyLevel  Float     @default(1)
  timesServed      Int       @default(0) // worksheets generated containing this topic
  servesSinceGrade Int       @default(0) // consecutive serves with no grading feedback
  lastServedAt     DateTime?
  formatsJson      String?   // recent question formats served (variety rotation)
  missesJson       String?   // recent wrong answers (question/studentAnswer/feedback)
  figuresJson      String?   // recent figure signatures served (visual variety)

  @@unique([childId, topicId])
}

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "generate" | "grade" | "credit" | "refund"
  worksheetId String?
  creditsCost Int
  createdAt   DateTime @default(now())

  @@index([userId, type])
}

// Immutable record of admin/product actions (refunds, credit grants, plan
// edits) so customer-support decisions are traceable.
model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String?
  action     String   // e.g. "refund", "credit-grant", "ticket-resolve"
  targetType String?  // e.g. "user", "worksheet", "ticket"
  targetId   String?
  detailJson String?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
}

model SupportTicket {
  id         String    @id @default(cuid())
  email      String
  subject    String
  message    String
  status     String    @default("open") // open | resolved
  notes      String?   // internal admin notes
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status, createdAt])
}
